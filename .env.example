# Copy to .env (gitignored) and fill in to point the local compose stack at real tenants.
# Leave everything blank for the UI-only demo: auth is off and the Microsoft plane is inert.
# See https://spillers-technology.github.io/PartnerCenterBridge/getting-started.html for the
# app-registration permissions these credentials need.

# Multi-tenant Entra app registration in your partner tenant (Secure Application Model).
PARTNER_CLIENT_ID=
PARTNER_CLIENT_SECRET=
PARTNER_TENANT_ID=

# Optional: seed refresh token captured out-of-band. Prefer the interactive
# `dotnet run --project src/PartnerCenterBridge.Api -- bootstrap-sam` flow instead.
PARTNER_SEED_REFRESH_TOKEN=

# Exchange Online app-only certificate auth (mailbox workflows only).
# The certificate itself must be placed at /certs/exo.pfx inside the api container
# (the compose file mounts the named volume "certs" there).
EXCHANGE_APP_ID=
EXCHANGE_CERT_PASSWORD=
